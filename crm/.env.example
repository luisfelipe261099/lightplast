# ==================== TIDB CLOUD ====================
# Configure com suas credenciais TiDB Cloud
TIDB_HOST=gateway01us-east1prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=seu_usuario_tidb_cloud
TIDB_PASSWORD=sua_senha_tidb_cloud
TIDB_DATABASE=seu_database

# ==================== ENVIRONMENT ====================
NODE_ENV=production
PORT=3000

# ==================== WHATSAPP (OPTIONAL) ====================
WHATSAPP_API_KEY=seu_whatsapp_api_key
WHATSAPP_PHONE_ID=seu_phone_id

SMTP_PASSWORD=your_app_password

# Vercel Deployment
VERCEL=1
