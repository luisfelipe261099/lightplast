{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "env": {
    "TIDB_HOST": "@tidb_host",
    "TIDB_PORT": "@tidb_port",
    "TIDB_USER": "@tidb_user",
    "TIDB_PASSWORD": "@tidb_password",
    "TIDB_DATABASE": "@tidb_database",
    "NODE_ENV": "production"
  },
  "functions": {
    "index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/index.js"
    },
    {
      "source": "/crm",
      "destination": "/crm-pro.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
