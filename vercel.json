{
  "version": 2,
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "index.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "{*.html,style.css,assets/**,sitemap.xml,robots.txt}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.js"
    }
  ]
}
