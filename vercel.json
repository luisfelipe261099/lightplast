{
  "buildCommand": "cd crm && npm run build",
  "outputDirectory": "crm/dist",
  "framework": "other",
  "env": [
    "TIDB_HOST",
    "TIDB_PORT",
    "TIDB_USER",
    "TIDB_PASSWORD",
    "TIDB_DATABASE",
    "NODE_ENV"
  ],
  "rewrites": [
    {
      "source": "/crm/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
