{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "index.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": [
        "index.html",
        "crm-pro.html",
        "style.css",
        "assets/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/index.js"
    },
    {
      "source": "/crm",
      "destination": "/crm-pro.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
