{
    "outputDirectory":  "crm/dist",
    "buildCommand":  "npm ci --prefix crm && npm run build --prefix crm",
    "rewrites":  [
                     {
                         "destination":  "/api/$1",
                         "source":  "/crm/api/(.*)"
                     },
                     {
                         "destination":  "/crm.html",
                         "source":  "/crm"
                     }
                 ]
}
