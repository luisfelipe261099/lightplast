{
  "version": 2,
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/crm",
      "destination": "/crm-pro.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
