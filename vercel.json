{
    "outputDirectory":  "crm/dist",
    "buildCommand":  "cd crm \u0026\u0026 npm install \u0026\u0026 npm run build",
    "rewrites":  [
                     {
                         "destination":  "/api/$1",
                         "source":  "/crm/api/(.*)"
                     },
                     {
                         "destination":  "/crm.html",
                         "source":  "/crm"
                     }
                 ]
}
